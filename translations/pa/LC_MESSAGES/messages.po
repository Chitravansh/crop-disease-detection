msgstr "ਤੁਰੰਤ ਪਛਾਣ"

#: app/templates/home.html:29
msgid ""
"Upload a leaf image and receive disease prediction within\n"
"          seconds."
msgstr "ਪੱਤੇ ਦੀ ਤਸਵੀਰ ਅਪਲੋਡ ਕਰੋ ਅਤੇ ਸਕਿੰਟਾਂ ਵਿੱਚ ਬਿਮਾਰੀ ਦੀ ਭਵਿੱਖਬਾਣੀ ਪ੍ਰਾਪਤ ਕਰੋ।"

#: app/templates/home.html:37
msgid "AI Powered"
msgstr "AI ਦੁਆਰਾ ਸੰਚਾਲਿਤ"

#: app/templates/home.html:39
